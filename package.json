{
  "name": "gesp-learning-platform",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo run dev --filter=@gesp/web",
    "dev:backend": "turbo run dev --filter=@gesp/backend",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "db:push": "bunx drizzle-kit push",
    "seed:knowledge": "bun run scripts/seed-knowledge.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "tsx": "^4.21.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@lancedb/lancedb-darwin-arm64": "0.27.2"
  }
}
