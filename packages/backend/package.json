{
  "name": "@gesp/backend",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "db:push": "drizzle-kit push --force",
    "build": "bun build ./src/index.ts --outdir ./dist",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "seed:knowledge": "EMBEDDING_PROVIDER=mock bun run src/seed/knowledge.seed.ts"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.2.2",
    "@hono/zod-validator": "^0.7.6",
    "@lancedb/lancedb": "0.22.3",
    "@lancedb/lancedb-darwin-arm64": "0.27.2",
    "@scalar/hono-api-reference": "^0.10.10",
    "bcryptjs": "^3.0.0",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.0.0",
    "hono-openapi": "^1.0.0",
    "pino": "^9.0.0",
    "zod": "^4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "better-sqlite3": "^12.9.0",
    "bun-types": "^1.3.0",
    "drizzle-kit": "^0.30.0",
    "pino-pretty": "^11.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}