[
  { "id": "kp-l1-001", "language": "C++", "level": 1, "block": "计算机基础知识", "block_order": 1, "point": "计算机软硬件组成", "point_order": 1, "mastery_verb": "掌握", "description": "计算机由硬件（CPU、内存、硬盘、输入输出设备）和软件（系统软件、应用软件）组成", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-002", "language": "C++", "level": 1, "block": "计算机基础知识", "block_order": 1, "point": "操作系统概念", "point_order": 2, "mastery_verb": "掌握", "description": "操作系统是管理计算机硬件与软件资源的系统软件，如Windows、Linux、macOS", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-003", "language": "C++", "level": 1, "block": "计算机基础知识", "block_order": 1, "point": "计算机历史与发展", "point_order": 3, "mastery_verb": "了解", "description": "世界第一台电子计算机ENIAC诞生于1946年，经历了电子管、晶体管、集成电路、大规模集成电路四代", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-004", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "标识符", "point_order": 1, "mastery_verb": "掌握", "description": "标识符是以字母或下划线开头的由字母、数字、下划线组成的序列，用于命名变量、函数等，C++大小写敏感", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-005", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "关键字", "point_order": 2, "mastery_verb": "掌握", "description": "关键字是C++语言保留的有特殊含义的单词，如int、return、if、while、for等，不可用作标识符", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-006", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "常量与变量", "point_order": 3, "mastery_verb": "掌握", "description": "常量是程序运行中不可改变的值，用const修饰；变量是可改变的命名存储单元，必须先声明后使用", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-007", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "表达式", "point_order": 4, "mastery_verb": "掌握", "description": "表达式由运算符和操作数组成，能计算出一个值，如算术表达式、关系表达式、逻辑表达式", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-008", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "自增自减运算", "point_order": 5, "mastery_verb": "掌握", "description": "++和--运算符分为前置（先加减后使用）和后置（先使用后加减）两种形式", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-009", "language": "C++", "level": 1, "block": "程序的基本概念", "block_order": 2, "point": "程序注释", "point_order": 6, "mastery_verb": "掌握", "description": "单行注释用//，多行注释用/* */，注释不影响程序运行效率，编译时被忽略", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-010", "language": "C++", "level": 1, "block": "基本数据类型", "block_order": 3, "point": "整型", "point_order": 1, "mastery_verb": "掌握", "description": "整型包括short、int、long、long long，C++标准规定int至少16位，不同类型取值范围不同", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-011", "language": "C++", "level": 1, "block": "基本数据类型", "block_order": 3, "point": "实数型", "point_order": 2, "mastery_verb": "掌握", "description": "实数型包括float（单精度）和double（双精度），double精度更高通常64位，浮点运算有精度误差", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-012", "language": "C++", "level": 1, "block": "基本数据类型", "block_order": 3, "point": "字符型", "point_order": 3, "mastery_verb": "掌握", "description": "char类型存储单个字符，占1字节，实际存储ASCII码值，参与运算时转为整数", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-013", "language": "C++", "level": 1, "block": "基本数据类型", "block_order": 3, "point": "布尔型", "point_order": 4, "mastery_verb": "掌握", "description": "bool类型取值为true或false，占1字节，可与整数互换（0为假，非0为真）", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-014", "language": "C++", "level": 1, "block": "基本运算", "block_order": 4, "point": "算术运算", "point_order": 1, "mastery_verb": "掌握", "description": "包括加减乘除(+,-,*,/)和取模(%)，整数除法向下取整，注意运算符优先级和结合性", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-015", "language": "C++", "level": 1, "block": "基本运算", "block_order": 4, "point": "逻辑运算", "point_order": 2, "mastery_verb": "掌握", "description": "逻辑与(&&)、逻辑或(||)、逻辑非(!)，具有短路求值特性", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-016", "language": "C++", "level": 1, "block": "基本运算", "block_order": 4, "point": "关系运算", "point_order": 3, "mastery_verb": "掌握", "description": "比较运算符(==,!=,<,>,<=,>=)返回bool值，注意==与=的区别", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-017", "language": "C++", "level": 1, "block": "基本运算", "block_order": 4, "point": "三目运算", "point_order": 4, "mastery_verb": "掌握", "description": "条件表达式: 条件 ? 表达式1 : 表达式2，条件为真取表达式1否则取表达式2", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-018", "language": "C++", "level": 1, "block": "程序的基本语句", "block_order": 5, "point": "输入输出语句", "point_order": 1, "mastery_verb": "掌握", "description": "cin用于输入，cout用于输出，endl换行并刷新缓冲区，printf/scanf格式化输入输出", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-019", "language": "C++", "level": 1, "block": "程序的基本语句", "block_order": 5, "point": "赋值语句", "point_order": 2, "mastery_verb": "掌握", "description": "赋值运算符=和复合赋值运算符(+=,-=,*=,/=)，赋值从右向左结合", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-020", "language": "C++", "level": 1, "block": "结构化程序设计", "block_order": 6, "point": "顺序结构", "point_order": 1, "mastery_verb": "掌握", "description": "程序从上到下逐条执行，是最基本的程序结构", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-021", "language": "C++", "level": 1, "block": "结构化程序设计", "block_order": 6, "point": "分支结构", "point_order": 2, "mastery_verb": "掌握", "description": "if-else条件判断和switch-case多分支选择，else与最近的未配对if匹配，switch注意break防穿透", "tags": ["基础语法", "概念"] },
  { "id": "kp-l1-022", "language": "C++", "level": 1, "block": "结构化程序设计", "block_order": 6, "point": "循环结构", "point_order": 3, "mastery_verb": "掌握", "description": "for循环适合已知次数、while先判后执行、do-while至少执行一次，break终止循环continue跳过本次", "tags": ["基础语法", "概念"] },
  { "id": "kp-l2-001", "language": "C++", "level": 2, "block": "数组和字符串", "block_order": 1, "point": "一维数组", "point_order": 1, "mastery_verb": "掌握", "description": "一维数组是相同类型元素的有序集合，下标从0开始，声明时需指定大小或通过初始化推断", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l2-002", "language": "C++", "level": 2, "block": "数组和字符串", "block_order": 1, "point": "二维数组", "point_order": 2, "mastery_verb": "掌握", "description": "二维数组是数组的数组，按行存储，常用于矩阵运算和表格数据", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l2-003", "language": "C++", "level": 2, "block": "数组和字符串", "block_order": 1, "point": "字符数组与字符串", "point_order": 3, "mastery_verb": "掌握", "description": "字符数组以'\\0'结尾表示字符串，cstring库提供strlen、strcpy、strcat、strcmp等函数", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l2-004", "language": "C++", "level": 2, "block": "数组和字符串", "block_order": 1, "point": "string类", "point_order": 4, "mastery_verb": "掌握", "description": "C++ string类封装了字符串操作，支持+拼接、[]访问、size()长度、find()查找等，比字符数组更安全", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l2-005", "language": "C++", "level": 2, "block": "函数", "block_order": 2, "point": "函数定义与调用", "point_order": 1, "mastery_verb": "掌握", "description": "函数由返回类型、函数名、参数列表和函数体组成，声明在前定义在后，支持值传递和引用传递", "tags": ["基础语法", "概念"] },
  { "id": "kp-l2-006", "language": "C++", "level": 2, "block": "函数", "block_order": 2, "point": "递归函数", "point_order": 2, "mastery_verb": "理解", "description": "递归是函数直接或间接调用自身，必须有终止条件和递推关系，如阶乘、斐波那契数列", "tags": ["基础语法", "递归与分治"] },
  { "id": "kp-l2-007", "language": "C++", "level": 2, "block": "函数", "block_order": 2, "point": "变量作用域", "point_order": 3, "mastery_verb": "掌握", "description": "局部变量在函数/块内有效，全局变量在整个文件有效，静态变量保持值跨越函数调用", "tags": ["基础语法", "概念"] },
  { "id": "kp-l3-001", "language": "C++", "level": 3, "block": "指针", "block_order": 1, "point": "指针基础", "point_order": 1, "mastery_verb": "掌握", "description": "指针变量存储内存地址，用&取地址，用*解引用，指针的类型决定解引用时读取的字节数", "tags": ["基础语法", "概念"] },
  { "id": "kp-l3-002", "language": "C++", "level": 3, "block": "指针", "block_order": 1, "point": "指针与数组", "point_order": 2, "mastery_verb": "掌握", "description": "数组名是首元素地址的常量指针，指针算术访问数组元素，*(a+i)等价于a[i]", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l3-003", "language": "C++", "level": 3, "block": "结构体", "block_order": 2, "point": "结构体定义与使用", "point_order": 1, "mastery_verb": "掌握", "description": "struct将不同类型数据组合为一个整体，用.访问成员，用->通过指针访问成员", "tags": ["基础语法", "数据结构"] },
  { "id": "kp-l3-004", "language": "C++", "level": 3, "block": "排序算法", "block_order": 3, "point": "冒泡排序", "point_order": 1, "mastery_verb": "掌握", "description": "相邻元素两两比较交换，每轮将最大值冒泡到末尾，时间复杂度O(n²)", "tags": ["排序算法"] },
  { "id": "kp-l3-005", "language": "C++", "level": 3, "block": "排序算法", "block_order": 3, "point": "选择排序", "point_order": 2, "mastery_verb": "掌握", "description": "每轮选出最小元素放到已排序序列末尾，时间复杂度O(n²)", "tags": ["排序算法"] },
  { "id": "kp-l3-006", "language": "C++", "level": 3, "block": "排序算法", "block_order": 3, "point": "插入排序", "point_order": 3, "mastery_verb": "掌握", "description": "将待排序元素插入到已排序序列的正确位置，对近乎有序的数据效率较高", "tags": ["排序算法"] },
  { "id": "kp-l4-001", "language": "C++", "level": 4, "block": "类与对象", "block_order": 1, "point": "类定义与封装", "point_order": 1, "mastery_verb": "掌握", "description": "class定义类，包含成员变量和成员函数，通过public/private/protected控制访问权限", "tags": ["基础语法", "概念"] },
  { "id": "kp-l4-002", "language": "C++", "level": 4, "block": "类与对象", "block_order": 1, "point": "构造函数与析构函数", "point_order": 2, "mastery_verb": "掌握", "description": "构造函数在对象创建时自动调用用于初始化，析构函数在对象销毁时自动调用用于清理资源", "tags": ["基础语法", "概念"] },
  { "id": "kp-l4-003", "language": "C++", "level": 4, "block": "算法基础", "block_order": 2, "point": "二分查找", "point_order": 1, "mastery_verb": "掌握", "description": "在有序数组中通过不断折半缩小查找范围，时间复杂度O(log n)，注意边界条件处理", "tags": ["算法"] },
  { "id": "kp-l4-004", "language": "C++", "level": 4, "block": "算法基础", "block_order": 2, "point": "快速排序", "point_order": 2, "mastery_verb": "掌握", "description": "分治法选取基准元素，将数组分为小于和大于基准的两部分递归排序，平均O(n log n)", "tags": ["排序算法"] },
  { "id": "kp-l4-005", "language": "C++", "level": 4, "block": "数据结构基础", "block_order": 3, "point": "栈", "point_order": 1, "mastery_verb": "掌握", "description": "后进先出(LIFO)数据结构，支持push入栈、pop出栈、top获取栈顶，可用于表达式求值和括号匹配", "tags": ["数据结构"] },
  { "id": "kp-l4-006", "language": "C++", "level": 4, "block": "数据结构基础", "block_order": 3, "point": "队列", "point_order": 2, "mastery_verb": "掌握", "description": "先进先出(FIFO)数据结构，支持push入队、pop出队、front获取队首，常用于BFS广度优先搜索", "tags": ["数据结构"] },
  { "id": "kp-l5-001", "language": "C++", "level": 5, "block": "STL标准模板库", "block_order": 1, "point": "vector动态数组", "point_order": 1, "mastery_verb": "掌握", "description": "STL vector是动态数组，自动扩容，支持push_back、pop_back、size、[]访问和迭代器遍历", "tags": ["数据结构", "基础语法"] },
  { "id": "kp-l5-002", "language": "C++", "level": 5, "block": "STL标准模板库", "block_order": 1, "point": "map和set", "point_order": 2, "mastery_verb": "掌握", "description": "map是键值对有序映射，set是不重复元素有序集合，底层红黑树实现，查找O(log n)", "tags": ["数据结构", "基础语法"] },
  { "id": "kp-l5-003", "language": "C++", "level": 5, "block": "STL标准模板库", "block_order": 1, "point": "algorithm算法库", "point_order": 3, "mastery_verb": "掌握", "description": "STL提供sort、find、reverse、lower_bound、upper_bound、next_permutation等通用算法", "tags": ["算法", "基础语法"] },
  { "id": "kp-l5-004", "language": "C++", "level": 5, "block": "递归与分治", "block_order": 2, "point": "递归与分治思想", "point_order": 1, "mastery_verb": "掌握", "description": "分治法将大问题分解为结构相同的子问题分别求解再合并，如归并排序、快速幂", "tags": ["递归与分治"] },
  { "id": "kp-l5-005", "language": "C++", "level": 5, "block": "搜索算法", "block_order": 3, "point": "深度优先搜索(DFS)", "point_order": 1, "mastery_verb": "掌握", "description": "DFS沿一条路径深入到底再回溯，用递归或栈实现，可用于全排列、组合、迷宫求解", "tags": ["算法"] },
  { "id": "kp-l5-006", "language": "C++", "level": 5, "block": "搜索算法", "block_order": 3, "point": "广度优先搜索(BFS)", "point_order": 2, "mastery_verb": "掌握", "description": "BFS逐层扩展搜索，用队列实现，可求无权图最短路径", "tags": ["算法"] },
  { "id": "kp-l6-001", "language": "C++", "level": 6, "block": "链表", "block_order": 1, "point": "单链表", "point_order": 1, "mastery_verb": "掌握", "description": "链表节点包含数据和指向下一节点的指针，支持O(1)插入删除，但不支持随机访问", "tags": ["数据结构"] },
  { "id": "kp-l6-002", "language": "C++", "level": 6, "block": "链表", "block_order": 1, "point": "双向链表与循环链表", "point_order": 2, "mastery_verb": "理解", "description": "双向链表每个节点有前驱和后继指针，循环链表尾节点指向头节点", "tags": ["数据结构"] },
  { "id": "kp-l6-003", "language": "C++", "level": 6, "block": "二叉树", "block_order": 2, "point": "二叉树基础", "point_order": 1, "mastery_verb": "掌握", "description": "二叉树每个节点最多有两个子节点，三种遍历：前序(根左右)、中序(左根右)、后序(左右根)", "tags": ["数据结构"] },
  { "id": "kp-l6-004", "language": "C++", "level": 6, "block": "二叉树", "block_order": 2, "point": "二叉搜索树", "point_order": 2, "mastery_verb": "掌握", "description": "BST满足左子树<根<右子树，查找/插入/删除平均O(log n)，最坏退化为链表O(n)", "tags": ["数据结构"] },
  { "id": "kp-l6-005", "language": "C++", "level": 6, "block": "数论基础", "block_order": 3, "point": "素数判定", "point_order": 1, "mastery_verb": "掌握", "description": "素数是大于1的自然数且只能被1和自身整除，试除法判素到√n，埃氏筛法批量求素数", "tags": ["数论"] },
  { "id": "kp-l6-006", "language": "C++", "level": 6, "block": "数论基础", "block_order": 3, "point": "最大公约数与最小公倍数", "point_order": 2, "mastery_verb": "掌握", "description": "欧几里得算法(gcd): gcd(a,b) = gcd(b, a%b)，lcm(a,b) = a*b/gcd(a,b)", "tags": ["数论"] },
  { "id": "kp-l7-001", "language": "C++", "level": 7, "block": "动态规划", "block_order": 1, "point": "动态规划基础", "point_order": 1, "mastery_verb": "掌握", "description": "将问题分解为重叠子问题，记忆化存储中间结果避免重复计算，关键要素：状态定义、转移方程、初始条件", "tags": ["动态规划"] },
