# GESP Backend Environment Configuration
# Copy this file to .env and fill in your values

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=./data/gesp.db

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# ---------------------------------------------------------------------------
# Session
# ---------------------------------------------------------------------------
SESSION_SECRET=your-secret-key-change-in-production

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
# Log level: fatal > error > warn > info > debug > trace
LOG_LEVEL=info
# Log file directory (default: ./logs)
LOG_DIR=./logs
# Log file name (default: gesp.log)
LOG_FILE=gesp.log
# Max rotated files to keep (default: 7)
LOG_MAX_FILES=7

# ---------------------------------------------------------------------------
# Embedding (Ollama local for dev)
# ---------------------------------------------------------------------------
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://macmini.local:11434/v1
EMBEDDING_MODEL=nomic-embed-text-v2-moe

# Fallback to OpenAI
# EMBEDDING_PROVIDER=openai
# OPENAI_API_KEY=sk-xxx

# For tests (no Ollama needed)
# EMBEDDING_PROVIDER=mock

# ---------------------------------------------------------------------------
# Assessment (Phase 03) — CHANGE in production
# ---------------------------------------------------------------------------
JWT_SECRET=your-assessment-jwt-secret
GESP_API_KEY=your-gesp-plugin-api-key
ELLAMAKA_URL=http://localhost:4141
ELLAMAKA_DIRECTORY=/path/to/gesp